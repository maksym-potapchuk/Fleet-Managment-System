{
  "dashboard": {
    "id": null,
    "uid": "redis-cache",
    "title": "Redis Cache",
    "tags": ["redis", "cache"],
    "timezone": "browser",
    "refresh": "30s",
    "time": {
      "from": "now-1h",
      "to": "now"
    },
    "panels": [
      {
        "id": 1,
        "type": "gauge",
        "title": "Cache Hit Ratio",
        "gridPos": { "x": 0, "y": 0, "h": 8, "w": 8 },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "orange", "value": 0.5 },
                { "color": "yellow", "value": 0.7 },
                { "color": "green", "value": 0.85 }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "redis_keyspace_hits_total / (redis_keyspace_hits_total + redis_keyspace_misses_total)",
            "legendFormat": "Hit Ratio"
          }
        ]
      },
      {
        "id": 2,
        "type": "stat",
        "title": "Hits / sec",
        "gridPos": { "x": 8, "y": 0, "h": 4, "w": 4 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "irate(redis_keyspace_hits_total[5m])",
            "legendFormat": "hits/s"
          }
        ]
      },
      {
        "id": 3,
        "type": "stat",
        "title": "Misses / sec",
        "gridPos": { "x": 12, "y": 0, "h": 4, "w": 4 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "orange", "value": 1 },
                { "color": "red", "value": 5 }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "irate(redis_keyspace_misses_total[5m])",
            "legendFormat": "misses/s"
          }
        ]
      },
      {
        "id": 4,
        "type": "stat",
        "title": "Connected Clients",
        "gridPos": { "x": 16, "y": 0, "h": 4, "w": 4 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 50 },
                { "color": "red", "value": 100 }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "redis_connected_clients",
            "legendFormat": "clients"
          }
        ]
      },
      {
        "id": 5,
        "type": "stat",
        "title": "Used Memory",
        "gridPos": { "x": 20, "y": 0, "h": 4, "w": 4 },
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "yellow", "value": 104857600 },
                { "color": "red", "value": 268435456 }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "redis_memory_used_bytes",
            "legendFormat": "used"
          }
        ]
      },
      {
        "id": 6,
        "type": "stat",
        "title": "Total Keys",
        "gridPos": { "x": 8, "y": 4, "h": 4, "w": 4 },
        "fieldConfig": {
          "defaults": {
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "sum(redis_db_keys)",
            "legendFormat": "keys"
          }
        ]
      },
      {
        "id": 7,
        "type": "stat",
        "title": "Expired Keys / sec",
        "gridPos": { "x": 12, "y": 4, "h": 4, "w": 4 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "irate(redis_expired_keys_total[5m])",
            "legendFormat": "expired/s"
          }
        ]
      },
      {
        "id": 8,
        "type": "stat",
        "title": "Evicted Keys / sec",
        "gridPos": { "x": 16, "y": 4, "h": 4, "w": 4 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "color": { "mode": "thresholds" },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "green", "value": null },
                { "color": "red", "value": 1 }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "irate(redis_evicted_keys_total[5m])",
            "legendFormat": "evicted/s"
          }
        ]
      },
      {
        "id": 9,
        "type": "timeseries",
        "title": "Cache Hit Ratio Over Time",
        "gridPos": { "x": 0, "y": 8, "h": 8, "w": 12 },
        "fieldConfig": {
          "defaults": {
            "unit": "percentunit",
            "min": 0,
            "max": 1,
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 15,
              "showPoints": "never"
            },
            "thresholds": {
              "mode": "absolute",
              "steps": [
                { "color": "red", "value": null },
                { "color": "green", "value": 0.85 }
              ]
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "irate(redis_keyspace_hits_total[5m]) / (irate(redis_keyspace_hits_total[5m]) + irate(redis_keyspace_misses_total[5m]))",
            "legendFormat": "Hit Ratio"
          }
        ]
      },
      {
        "id": 10,
        "type": "timeseries",
        "title": "Commands / sec",
        "gridPos": { "x": 12, "y": 8, "h": 8, "w": 12 },
        "fieldConfig": {
          "defaults": {
            "unit": "ops",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 1,
              "fillOpacity": 10,
              "showPoints": "never"
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "irate(redis_commands_processed_total[5m])",
            "legendFormat": "commands/s"
          }
        ]
      },
      {
        "id": 11,
        "type": "timeseries",
        "title": "Memory Usage",
        "gridPos": { "x": 0, "y": 16, "h": 8, "w": 12 },
        "fieldConfig": {
          "defaults": {
            "unit": "bytes",
            "custom": {
              "drawStyle": "line",
              "lineWidth": 2,
              "fillOpacity": 15,
              "showPoints": "never"
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "redis_memory_used_bytes",
            "legendFormat": "Used"
          },
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "redis_memory_max_bytes > 0",
            "legendFormat": "Max"
          }
        ]
      },
      {
        "id": 12,
        "type": "timeseries",
        "title": "Keys Over Time",
        "gridPos": { "x": 12, "y": 16, "h": 8, "w": 12 },
        "fieldConfig": {
          "defaults": {
            "custom": {
              "drawStyle": "line",
              "lineWidth": 1,
              "fillOpacity": 10,
              "showPoints": "never"
            }
          }
        },
        "targets": [
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "sum(redis_db_keys)",
            "legendFormat": "Total Keys"
          },
          {
            "datasource": { "type": "prometheus", "uid": "prometheus" },
            "expr": "sum(redis_db_keys_expiring)",
            "legendFormat": "Keys with TTL"
          }
        ]
      }
    ],
    "schemaVersion": 39
  },
  "overwrite": true
}
