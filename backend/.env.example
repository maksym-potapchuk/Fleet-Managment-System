SECRET_KEY="your-secret-key-here"
DEBUG=True
ALLOWED_HOSTS=*

# Neon Postgres connection
POSTGRES_DB=your_db_name
POSTGRES_USER=your_db_user
POSTGRES_PASSWORD=your_db_password
POSTGRES_HOST=your-neon-host.neon.tech
POSTGRES_PORT=5432

ACCESS_TOKEN_LIFETIME=86400
REFRESH_TOKEN_LIFETIME=604800

# Cookie security - set to True in production (requires HTTPS)
SECURE_COOKIES=False

# CORS & CSRF — set for production domain (comma-separated)
# CORS_ALLOWED_ORIGINS=https://fdfleetmanager.site
# CSRF_TRUSTED_ORIGINS=https://fdfleetmanager.site

# Throttling
# THROTTLE_ANON=30/minute
# THROTTLE_USER=300/minute
# THROTTLE_AUTH=5/minute
